---
import { SITE_TITLE } from "../consts";
import NavLink from "./NavLink.astro";
import { NAV_LINKS } from "../consts";
---

<header class="fixed left-0 right-0 top-0 z-50 bg-black text-white">
  <nav class="h-12 flex items-center justify-between general-padding">
    <h2>
      <a href="/" class="hover:opacity-80 transition-opacity">{SITE_TITLE}</a>
    </h2>

    <div class="flex gap-4">
      {
        NAV_LINKS.map((link) => (
          <NavLink key={link.key} href={link.href}>
            {link.name}
          </NavLink>
        ))
      }
    </div>
  </nav>
</header>
