---
import FormattedDate from "../components/FormattedDate.astro";
import { Image } from "astro:assets";
import defaultHero from "../assets/blog/default-hero.webp";

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      author: string;
      pubDate: Date;
      updatedDate?: Date;
      heroImage?: ImageMetadata;
      inspo?: string;
    };
  };
}

const { post } = Astro.props;
const { title, description, pubDate, heroImage, author } = post.data;

const slug = post.id;

const imageToDisplay = heroImage || defaultHero;
---

<a
  href={`/blog/${slug}`}
  class="group block relative bg-white border border-gray-200 border-t-black border-t-2 transition-shadow duration-300 hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,0.85)] overflow-hidden"
>
  <div class="relative overflow-hidden">
    <Image
      src={imageToDisplay}
      alt={title}
      width={720}
      height={400}
      transition:name={`blog-hero-${slug}`}
      class="w-full object-cover aspect-video group-hover:scale-105 transition-transform duration-700 ease-out"
    />

    <div
      class="absolute bottom-0 left-0 bg-white px-3 py-1 text-[0.7rem] tracking-[0.08em] text-[#555] border-t border-r border-gray-200"
    >
      <FormattedDate date={pubDate} />
    </div>
  </div>

  <div class="pt-4 pb-2 pl-4">
    <p class="text-xs tracking-widest uppercase mb-2 text-gray-400">
      {author}
    </p>
    <h4
      class="font-bold leading-tight mb-2 text-2xl line-clamp-1"
      transition:name={`blog-title-${slug}`}
    >
      {title}
    </h4>
    <p class="text-sm text-gray-500 leading-relaxed line-clamp-1">
      {description}
    </p>

    <span
      class="inline-flex items-center gap-1 mt-4 text-xs tracking-widest uppercase font-semibold text-[#111] border-b border-[#111] pb-px"
    >
      Leer más
      <svg
        class="w-3 h-3 transition-transform duration-300 group-hover:translate-x-1"
        viewBox="0 0 12 12"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M1 6h10M7 2l4 4-4 4"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="square"></path>
      </svg>
    </span>
  </div>

  <div
    class="absolute bottom-0 left-0 w-0 h-0.5 bg-black group-hover:w-full transition-all duration-500 ease-out"
  >
  </div>
</a>
