---
import GeneralLayout from "../layouts/GeneralLayout.astro";
import { getCollection } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";
import BlogCard from "../components/BlogCard.astro";

const projects = (await getCollection("portfolio"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<GeneralLayout>
  <section id="hero">
    <section id="hero" class="relative">
      <div
        class="general-padding py-48 flex items-center justify-between overflow-hidden relative"
      >
        <h1 class="text-6xl font-serif md:w-1/2 text-left">
          Comparto mis ideas y realizo las tuyas
        </h1>
        <div class="hidden md:block"></div>
      </div>
    </section>
  </section>

  <section id="projects" class="bg-black text-white text-right relative py-16">
    <div class="general-padding pb-8">
      <h2 class="text-6xl text-red font-serif text-right mb-8">Proyectos</h2>
      <p class="text-lg">Aquí están algunos de mis proyectos más recientes.</p>
    </div>
    <div class="general-padding pt-2">
      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md-gap-8">
        {
          projects.map((project) => (
            <li>
              <ProjectCard project={project} loading="eager" />
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section id="me" class="bg-white text-black text-left relative py-16">
    <div class="general-padding pb-8">
      <h2 class="text-6xl text-blue font-serif text-left mb-8">Sobre mí</h2>
      <p class="text-lg">+5 años de experiencia. Ingeniero de Software</p>
      <p class="text-lg">
        Especializado en el desarrollo de aplicaciones web únicas.
      </p>
    </div>
    <div class="general-padding pt-2">
      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md-gap-8">
        {
          posts.map((post) => (
            <li>
              <BlogCard post={post} loading="lazy" />
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</GeneralLayout>
